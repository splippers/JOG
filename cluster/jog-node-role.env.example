# Optional: copy to /etc/jog/cluster.env (wizard may create this file).

# standalone | primary | edge
JOG_CLUSTER_MODE=standalone

# For edge nodes: rsync source for /images (SSH). Example: jogadmin@10.99.0.1
JOG_PRIMARY_SSH=

# Local directory that should mirror primary /images (host path; bind-mount into FOG if used)
JOG_LOCAL_IMAGES_DIR=/images
