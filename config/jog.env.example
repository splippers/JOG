# Copy to /etc/jog/jog.env and edit. Used by jog-render-dnsmasq.sh and kiosk scripts.

# --- Imaging (USB3 Ethernet only) ---
# Interface name for the USB NIC (use: ip -br link)
# Example: enx00e04c680001
JOG_USB_IFACE=enxREPLACE_ME

# Static address on the imaging link (must match dhcp-range subnet below)
JOG_IMAGING_IP=10.99.0.1
JOG_IMAGING_PREFIX=24

# DHCP pool served ONLY on JOG_USB_IFACE
JOG_DHCP_START=10.99.0.100
JOG_DHCP_END=10.99.0.200
JOG_DHCP_NETMASK=255.255.255.0
JOG_DHCP_LEASE_HOURS=12

# Handed to PXE clients as default gateway (usually the JOG laptop on this link)
JOG_DHCP_ROUTER=10.99.0.1

# TFTP / NEXT SERVER (siaddr) — must match the FOG server IP clients use for PXE TFTP
JOG_NEXT_SERVER=10.99.0.1

# PXE boot file served via TFTP from FOG (relative to tftpboot root). UEFI: snponly.efi or ubuntu-signed/shimx64.efi
JOG_DHCP_BOOTFILE=snponly.efi

# --- WiFi / updates (optional; for documentation in netplan snippet) ---
# JOG does not manage WiFi; keep a normal NetworkManager/netplan profile with lower
# metric than the imaging link so default route + DNS stay on WiFi for apt pulls.

# --- FOG / kiosk (FOG runs natively under /opt/fog; Apache on port 80) ---
# First Chromium tab on login (after graphical autologin — see docs/ISO-BUILD.md).
JOG_FOG_URL=http://localhost/fog/management/

# Optional extra tab if different from JOG_FOG_URL (e.g. specific task list)
JOG_FOG_TASKS_URL=

# Local status page (file://) generated by jog-refresh-status.service
JOG_STATUS_URL=file:///var/lib/jog/status/index.html

# Chromium kiosk: auto-restart if the browser exits (default 1). Set 0 to disable loop.
JOG_CHROMIUM_RESTART=1

# Optional extra Chromium flags (quoted string, split on spaces — advanced)
# JOG_CHROMIUM_EXTRA_FLAGS=
